---
import ArrowRight from "public/images/arrow-right.svg";
---

<div id="announcement-banner" class="fixed top-0 left-0 w-full z-[60] bg-gradient-red-5">
  <a
    href="https://fishjam.swmansion.com/real-time-composition"
    target="_blank"
    rel="noreferrer noopener"
    class="flex items-center justify-center gap-x-2 px-4 py-2.5 no-underline"
  >
    <span class="text-white text-sm sm:text-base font-medium leading-tight text-center">
      Smelter is becoming a managed service.
      <span class="font-semibold underline underline-offset-2 decoration-1">Sign up for early access</span>
    </span>
    <ArrowRight class="w-3.5 h-3.5 sm:w-4 sm:h-4 shrink-0" />
  </a>
</div>
